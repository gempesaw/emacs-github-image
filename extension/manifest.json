{
  "manifest_version": 3,
  "name": "Emacs GitHub Image",
  "version": "2.0.1",
  "description": "Upload images to GitHub CDN from Emacs (direct API, no DOM scraping)",
  "permissions": ["offscreen", "alarms", "declarativeNetRequestWithHostAccess"],
  "host_permissions": [
    "http://localhost/*",
    "https://github.com/*",
    "https://*.s3.amazonaws.com/*",
    "https://*.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ghimg-rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
